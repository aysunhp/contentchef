{
  "name": "contentchef",
  "version": "1.0.0",
  "description": "ContentChef - AI Content Planner",
  "private": true,
  "scripts": {
    "install:all": "npm install --prefix client && npm install --prefix server",
    "build:client": "npm run build --prefix client",
    "build": "npm run build:client",
    "start": "node server/src/app.js",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "dev": "npm run install:all && concurrently \"npm run dev:server\" \"npm run dev:client\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
